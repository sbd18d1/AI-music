# ============================================
# 数据库配置
# ============================================
# SQLite 数据库文件路径
DATABASE_URL="file:./dev.db"

# ============================================
# Stripe 支付配置
# ============================================
# Stripe 公钥（前端使用）- 在 Stripe Dashboard 获取
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here
# Stripe 密钥（后端使用）- 在 Stripe Dashboard 获取
STRIPE_SECRET_KEY=your_stripe_secret_key_here
# Stripe Webhook 签名密钥 - 使用 stripe listen 命令获取
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here

# ============================================
# 302.ai Suno API 配置
# ============================================
# 302.ai API 密钥（用于调用 Suno 音乐生成接口）- 在 302.ai 获取
THREE02_AI_KEY=your_302_ai_key_here
# 302.ai API 基础地址
# - 海外用户：https://api.302.ai
# - 国内用户：https://api.302api.com（直连优化）
THREE02_AI_BASE_URL=https://api.302.ai
# AI 生成模式："mock"（使用模拟数据）或 "real"（调用真实 API）
# - mock: 使用预设的测试音频，不消耗 API 余额，用于开发测试
# - real: 调用 302.ai Suno API，会消耗账户余额，用于生产环境
NEXT_PUBLIC_AI_GENERATION_MODE=mock

# ============================================
# Resend 邮件配置
# ============================================
# Resend API 密钥（用于发送订单完成通知邮件）- 在 Resend 获取
RESEND_API_KEY=your_resend_api_key_here
# 发送邮件的发件人地址（需要在 Resend 验证）
RESEND_FROM_EMAIL=noreply@yourdomain.com

# ============================================
# 应用配置
# ============================================
# 应用的公共 URL（用于支付回调和邮件链接）
# 开发环境：http://localhost:3000
# 生产环境：https://yourdomain.com
NEXT_PUBLIC_URL=http://localhost:3000

# ============================================
# 支付渠道配置
# ============================================
# 支付渠道选择："paypal" 或 "stripe"
# 默认使用 PayPal，可根据需求切换
NEXT_PUBLIC_PAYMENT_PROVIDER=paypal

# ============================================
# PayPal 支付配置
# ============================================
# PayPal 客户端 ID（前端使用）- 在 PayPal Developer 获取
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_sandbox_client_id_here
# PayPal 客户端密钥（后端使用）- 在 PayPal Developer 获取
PAYPAL_CLIENT_SECRET=your_paypal_sandbox_secret_here
# PayPal Webhook ID（用于验证回调）- 在 PayPal Developer 设置
PAYPAL_WEBHOOK_ID=your_paypal_webhook_id_here
# PayPal 模式："sandbox"（测试环境）或 "live"（生产环境）
PAYPAL_MODE=sandbox
