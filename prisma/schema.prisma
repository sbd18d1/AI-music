generator client {
  provider = "prisma-client"
  output = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Order {
  id                 String    @id @default(uuid())
  recipientName      String
  personality        String
  genre              String
  userEmail          String?
  customerEmail      String?
  selectedStyle      String?
  selectedArtistStyle String?
  songConfig         String?
  status             String    @default("pending")
  stripeSessionId    String?
  stripePaymentIntentId String?
  paypalOrderId      String?
  aiRequestId        String?
  audioUrl           String?
  lyrics             String?
  title              String?
  coverImageUrl      String?
  duration           String?
  isFullVersion      Boolean @default(false)
  ipAddress          String?
  deviceId           String?
  trialOrderId       String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([stripeSessionId])
  @@index([paypalOrderId])
  @@index([aiRequestId])
  @@index([status])
  @@index([ipAddress])
  @@index([deviceId])
  @@index([trialOrderId])
}

model TrialUsage {
  id        String    @id @default(uuid())
  ipAddress String?
  deviceId  String?
  usedAt    DateTime  @default(now())

  @@index([ipAddress])
  @@index([deviceId])
  @@index([usedAt])
}

model SongConfigDimension {
  id        String               @id @default(uuid())
  dimensionId String             @unique
  title     String
  subtitle  String?
  sortOrder Int                  @default(0)
  options   SongConfigOption[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  @@index([dimensionId])
  @@index([sortOrder])
}

model SongConfigOption {
  id              String               @id @default(uuid())
  optionId        String               @unique
  dimensionId     String
  dimension       SongConfigDimension  @relation(fields: [dimensionId], references: [dimensionId], onDelete: Cascade)
  icon            String
  name            String
  description     String
  styleTag        String?
  lyricInstruction String?
  genreValue      String?
  sortOrder       Int                  @default(0)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  @@index([dimensionId])
  @@index([optionId])
  @@index([sortOrder])
}
